{
  "screen_id": "obs-entry",
  "route": "/observe/entry",
  "title": "観測を記録する",
  "layout": "standard",
  "nodes": [
    {
      "id": "shell",
      "type": "app-shell",
      "children": [
        {
          "id": "page",
          "type": "page",
          "children": [
            { "id": "title", "type": "heading", "props": { "text": "観測を記録する", "level": 1 } },
            {
              "id": "find-target",
              "type": "button",
              "props": { "label": "対象を特定する", "variant": "secondary" },
              "action": { "kind": "navigate", "to": "obs-navigator" }
            },
            {
              "id": "capture-form",
              "type": "form",
              "action": { "kind": "navigate", "to": "obs-confirm" },
              "children": [
                { "id": "domain", "type": "field", "props": { "variant": "select", "name": "domain", "label": "観測ドメイン", "required": true, "placeholder": "ドメインを選ぶ", "options": [
                  { "value": "biology", "label": "生き物" },
                  { "value": "mineral", "label": "鉱物" },
                  { "value": "digital", "label": "デジタル" },
                  { "value": "place", "label": "場所" },
                  { "value": "custom", "label": "カスタム" }
                ] } },
                { "id": "species", "type": "field", "props": { "variant": "text", "name": "species_candidate", "label": "種の候補（任意・ユーザー入力）", "placeholder": "例: Dynastes hercules" } },
                { "id": "measure-item", "type": "field", "props": { "variant": "text", "name": "measurements.0.item", "label": "計測項目", "placeholder": "例: 体長", "required": true } },
                { "id": "measure-value", "type": "field", "props": { "variant": "number", "name": "measurements.0.value", "label": "計測値", "placeholder": "例: 65", "required": true } },
                { "id": "subject", "type": "field", "props": { "variant": "text", "name": "subject_ref", "label": "対象個体 ID（任意）", "placeholder": "individual/..." } },
                { "id": "sire", "type": "field", "props": { "variant": "text", "name": "sire_id", "label": "父個体 ID（任意）", "placeholder": "individual/..." } },
                { "id": "dam", "type": "field", "props": { "variant": "text", "name": "dam_id", "label": "母個体 ID（任意）", "placeholder": "individual/..." } },
                { "id": "photo", "type": "field", "props": { "variant": "photo", "name": "photo", "label": "写真" } },
                { "id": "submit", "type": "button", "props": { "label": "確認へ進む", "variant": "primary", "type": "submit" } }
              ]
            }
          ]
        }
      ]
    }
  ],
  "transitions": [
    { "from": "find-target", "to_screen_id": "obs-navigator", "label": "対象特定へ" },
    { "from": "capture-form", "to_screen_id": "obs-confirm", "label": "確認画面へ（保存は確認画面の登録で）" }
  ]
}
