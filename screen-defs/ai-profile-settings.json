{
  "screen_id": "ai-profile-settings",
  "route": "/s/ai-profile-settings",
  "title": "AI プロファイル設定",
  "layout": "standard",
  "notes": "V3-AIP-40 AI 機能ごとの差替可能プロファイル設定。BYOK 鍵はこの端末にのみ保持しサーバへ送らない(V3-SEC・LLM 既定 OFF=不変条項①)。ai-profiles/*.json が既定値の正本。計算資源目安 select(低/中/高/最高)+ 実行場所select(device既定/docker/cloud・V3-AIP-104 BYOC)+ BYOK 鍵 field + プロンプト textarea。route は追加しない(バンドル JSON をクライアントが読むデータ方式)。",
  "nodes": [
    {
      "id": "shell",
      "type": "app-shell",
      "children": [
        {
          "id": "page",
          "type": "page",
          "children": [
            { "id": "title", "type": "heading", "props": { "text": "AI プロファイル設定", "level": 1 } },
            {
              "id": "byok-note",
              "type": "card",
              "children": [
                { "id": "byok-title", "type": "heading", "props": { "text": "鍵の扱い", "level": 2 } },
                { "id": "byok-text", "type": "text", "props": { "text": "各 AI 機能は自分の API 鍵で動きます(BYOK)。鍵はこの端末にだけ保存され、サーバには送りません。既定では AI 機能はオフです。", "muted": true } }
              ]
            },
            {
              "id": "profile-form",
              "type": "form",
              "children": [
                { "id": "feature", "type": "field", "props": { "variant": "select", "name": "feature_id", "label": "対象の AI 機能", "placeholder": "機能を選ぶ", "options": [
                  { "value": "image-analysis", "label": "画像解析" },
                  { "value": "rag", "label": "検索補助(RAG)" },
                  { "value": "newspaper", "label": "新聞要約" },
                  { "value": "translation", "label": "翻訳" },
                  { "value": "market", "label": "取引提案" }
                ] } },
                { "id": "compute-tier", "type": "field", "props": { "variant": "select", "name": "compute_tier", "label": "計算資源の目安", "placeholder": "目安を選ぶ", "options": [
                  { "value": "low", "label": "低" },
                  { "value": "medium", "label": "中" },
                  { "value": "high", "label": "高" },
                  { "value": "max", "label": "最高" }
                ] } },
                { "id": "compute-location", "type": "field", "props": { "variant": "select", "name": "compute_location", "label": "実行場所(第一選択はこの端末)", "placeholder": "実行場所を選ぶ", "options": [
                  { "value": "device", "label": "この端末(既定・第一選択)" },
                  { "value": "docker", "label": "自分のDocker(収まらない高度解析のみ)" },
                  { "value": "cloud", "label": "クラウド(自分の鍵でBYOK)" }
                ] } },
                { "id": "byok-key", "type": "field", "props": { "variant": "text", "name": "byok_key", "label": "API 鍵(この端末にのみ保存)", "placeholder": "sk-..." } },
                { "id": "prompt", "type": "field", "props": { "variant": "textarea", "name": "prompt", "label": "既定プロンプト", "placeholder": "この機能に渡す既定の指示文" } },
                { "id": "save", "type": "button", "props": { "label": "この端末に保存する", "variant": "primary", "type": "submit" } }
              ]
            },
            {
              "id": "next-step",
              "type": "link",
              "props": { "label": "設定に戻る", "href": "/s/settings", "next_step": "設定に戻る" }
            }
          ]
        }
      ]
    }
  ],
  "transitions": []
}
