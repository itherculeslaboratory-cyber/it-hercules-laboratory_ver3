{
  "screen_id": "qr-resume",
  "route": "/qr/resume",
  "title": "観測を再開する",
  "layout": "standard",
  "nodes": [
    {
      "id": "shell",
      "type": "app-shell",
      "children": [
        {
          "id": "page",
          "type": "page",
          "children": [
            { "id": "title", "type": "heading", "props": { "text": "個体が見つかりました", "level": 1 } },
            { "id": "lead", "type": "text", "props": { "text": "この個体の文脈で、前回値を引き継いで観測を続けます。", "muted": true } },
            {
              "id": "resolve",
              "type": "card",
              "props": { "source_path": "/api/v1/qr/{{params.token}}?prefill=1" },
              "children": [
                { "id": "ind-id", "type": "text", "props": { "text": "個体 ID: {{data.resolve.individual_id}}" } },
                { "id": "entry-mode", "type": "text", "props": { "text": "入力モード: {{data.resolve.entry_mode}}", "muted": true } },
                { "id": "prefill-species", "type": "text", "props": { "text": "前回の種の候補: {{data.resolve.prefill.species_candidate}}", "muted": true } }
              ]
            },
            {
              "id": "resume",
              "type": "button",
              "props": { "label": "この個体で観測を続ける", "variant": "primary" },
              "action": { "kind": "navigate", "to": "obs-entry" }
            }
          ]
        }
      ]
    }
  ],
  "transitions": [
    { "from": "resume", "to_screen_id": "obs-entry", "label": "個体文脈付きで観測入力へ" }
  ]
}
