                  { "id": "hanashitai", "label": "話したい" },
                  { "id": "ronbun", "label": "論文" }
                ],
                "default_tab": "komatta"
              },
              "children": [
                {
                  "id": "komatta-lead",
                  "type": "text",
                  "props": {
                    "tab_id": "komatta",
                    "text_key": "knowledge-hub.komatta-lead.text",
                    "text": "何に困っているか打ってみてください。近いスレがあればそこへ合流できます。",
                    "muted": true
                  }
                },
                {
                  "id": "komatta-search",
                  "type": "list",
                  "props": {
                    "tab_id": "komatta",
                    "variant": "thread-search",
                    "source_path": "/api/v1/plaza/search"
                  }
                },
                {
                  "id": "hanashitai-lead",
                  "type": "text",
                  "props": {
                    "tab_id": "hanashitai",
                    "text_key": "knowledge-hub.hanashitai-lead.text",
                    "text": "同じ趣味の人と交流する。",
                    "muted": true
                  }
                },
                {
                  "id": "hanashitai-board",
                  "type": "card",
                  "props": { "tab_id": "hanashitai" },
                  "action": { "kind": "navigate", "to": "knowledge-board" },
                  "children": [
                    { "id": "hanashitai-board-title", "type": "heading", "props": { "text_key": "knowledge-hub.board.text", "text": "公式掲示板", "level": 2 } },
                    { "id": "hanashitai-board-desc", "type": "text", "props": { "text_key": "knowledge-hub.board-desc.text", "text": "説明・愚痴・改善の3板でチャネルごとに集約します。", "muted": true } }
                  ]
                },
                {
                  "id": "ronbun-lead",
                  "type": "text",
                  "props": {
                    "tab_id": "ronbun",
                    "text_key": "knowledge-hub.ronbun-lead.text",
                    "text": "論文を読む・書く・議論する。",
                    "muted": true
                  }
                },
                {
                  "id": "ronbun-paper",
                  "type": "card",
                  "props": { "tab_id": "ronbun" },
                  "action": { "kind": "navigate", "to": "knowledge-paper" },
                  "children": [
                    { "id": "ronbun-paper-title", "type": "heading", "props": { "text_key": "knowledge-hub.paper.text", "text": "論文", "level": 2 } },
                    { "id": "ronbun-paper-desc", "type": "text", "props": { "text_key": "knowledge-hub.paper-desc.text", "text": "論文の照合と引用の正本です。", "muted": true } }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "transitions": [
    { "from": "hanashitai-board", "to_screen_id": "knowledge-board", "label": "公式掲示板へ" },
    { "from": "ronbun-paper", "to_screen_id": "knowledge-paper", "label": "論文へ" }
  ]
