{
  "screen_id": "economy-status",
  "route": "/economy/status",
  "title": "ステータス",
  "layout": "standard",
  "notes": "KRM-16 統合ステータス。プラチナ/カルマ二層/3軸貢献度/称号 + append-only 履歴の読取投影。GET /me/status・/me/ledger・/me/contribution を都度再計算で表示。V3-UIX-68: history の bind 先が StatusHistoryEntry の実フィールド({{at}}/{{kind}})と一致していなかった旧退行({{created_at}}/{{label}}は存在しないキーで常に空表示)を修正。称号(title)を貢献度リストへ追加、PT影響力残高(GET /me/pt・非公開=本人のみ)も本画面に集約(新規画面を増やさない・V3-UIX-68)。",
  "nodes": [
    {
      "id": "shell",
      "type": "app-shell",
      "children": [
        {
          "id": "page",
          "type": "page",
          "children": [
            { "id": "title", "type": "heading", "props": { "text": "ステータス", "level": 1 } },
            { "id": "lead", "type": "text", "props": { "text": "プラチナ・カルマ・貢献度・称号を一画面で確認します。", "muted": true } },

            { "id": "karma-title", "type": "heading", "props": { "text": "カルマ", "level": 2 } },
            {
              "id": "karma",
              "type": "card",
              "props": {
                "source_path": "/api/v1/me/ledger",
                "bind_text": "値 {{karma_value}} / 累積カウント {{karma_count}} / プラチナ {{platinum_coins}}"
              }
            },

            { "id": "contribution-title", "type": "heading", "props": { "text": "貢献度（3軸・称号は閾値到達で表示）", "level": 2 } },
            {
              "id": "contribution",
              "type": "list",
              "props": {
                "source_path": "/api/v1/me/contribution",
                "bind_items": "data.contribution.axis_list",
                "item_text": "{{axis}}: {{score}}（鋳造 {{minted}} / 次閾値 {{next_threshold}} / 称号 {{title}}）"
              }
            },

            { "id": "pt-title", "type": "heading", "props": { "text": "PT影響力残高(非公開・本人のみ表示)", "level": 2 } },
            {
              "id": "pt",
              "type": "card",
              "props": { "source_path": "/api/v1/me/pt", "bind_text": "残高 {{balance}}" }
            },

            { "id": "history-title", "type": "heading", "props": { "text": "履歴（カルマ・プラチナ・貢献度）", "level": 2 } },
            {
              "id": "history",
              "type": "list",
              "props": {
                "source_path": "/api/v1/me/status",
                "bind_items": "data.history.history",
                "item_text": "{{at}} [{{kind}}]",
                "empty_text": "履歴はまだありません。"
              }
            },

            {
              "id": "open-shop",
              "type": "button",
              "props": { "label": "プラチナコインショップへ", "variant": "primary" },
              "action": { "kind": "navigate", "to": "platinum-shop" }
            },
            {
              "id": "open-profile",
              "type": "button",
              "props": { "label": "プロフィールを見る", "variant": "secondary" },
              "action": { "kind": "navigate", "to": "profile" }
            },
            {
              "id": "open-costs",
              "type": "button",
              "props": { "label": "運営コストを見る", "variant": "secondary" },
              "action": { "kind": "navigate", "to": "costs" }
            }
          ]
        }
      ]
    }
  ],
  "transitions": [
    { "from": "open-shop", "to_screen_id": "platinum-shop", "label": "プラチナコインショップへ" },
    { "from": "open-profile", "to_screen_id": "profile", "label": "プロフィールへ" },
    { "from": "open-costs", "to_screen_id": "costs", "label": "運営コストへ" }
  ]
}
