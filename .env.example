# .env.example — シークレットの「型」だけを持つテンプレート。
# 実値は絶対にコミットしない（実値はローカル .env / VPS の .env.platform / Workers secret のみ）。
# 使い方: このファイルを .env にコピーし、各値を実値で埋める。.env は .gitignore 済み。
# 実鍵の投入は人間ゲート（GMO 本番契約・Resend 実鍵・公開実施）。

# ─────────────────────────────────────────────────────────────
# GMO あおぞらネット銀行 — 振込判定コネクタ（design-c4 §2 / CL-11 / V3-MKT-14）
# 段階: sunabar（無料 sandbox・審査なし・AI 完結可）→ live（本番口座 API・人間ゲート）。
# sunabar トークンはポータル画面からコピー（最終ログインから30日超で失効）。
# TOKEN1 = 受取口座の READ（入出金明細 poll）用。TOKEN2/3 は E2E 擬似入金の振込元
# （更新系=金銭移動 → 人間ゲート）。実値は D:\env\platform.env のみ・コミット禁止。
# ─────────────────────────────────────────────────────────────
GMO_CONNECTOR_MODE=sunabar                    # sunabar / live（live は人間ゲートまで throw）
GMO_SUNABAR_API_BASE=https://api.sunabar.gmo-aozora.com/personal/v1 # sunabar 実ホスト
GMO_SUNABAR_ACCOUNT_ID=000000000000           # 受取口座 accountId（GET /accounts で確認）
GMO_SUNABAR_TOKEN1=xxxxx-sunabar-read-token   # READ（入出金明細照会）用トークン
GMO_SUNABAR_TOKEN2=xxxxx-sunabar-token-2       # E2E 擬似入金 振込元 A（更新系=人間ゲート）
GMO_SUNABAR_TOKEN3=xxxxx-sunabar-token-3       # E2E 擬似入金 振込元 B（更新系=人間ゲート）
# 本番（live）契約後: 銀行発行の client_id/secret + OAuth2.0/OIDC + api.gmo-aozora.com。
GMO_AOZORA_CLIENT_ID=your-client-id          # 銀行発行クライアント ID（live・人間ゲート）
GMO_AOZORA_CLIENT_SECRET=your-client-secret  # 銀行発行シークレット（live・人間ゲート）

# ─────────────────────────────────────────────────────────────
# Resend — メール送信（マジックリンク等）。無料枠 3,000通/月・ドメイン it-hercules.uk。
# 取得: https://resend.com → API Keys で発行。SMTP 互換（smtp.resend.com / user=resend / pass=APIキー）。
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx    # Resend API キー（実鍵投入は人間ゲート）
MAIL_FROM=IT Hercules Laboratory <login@send.it-hercules.uk>

# ─────────────────────────────────────────────────────────────
# 認証（C2）— 署名付きステートレスセッション（V3-AUT-03）。JWT ライブラリ不使用。
# SESSION_SECRET は wrangler secret / .dev.vars（.gitignore 済）で投入。
# ─────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-32+bytes-random     # HMAC-SHA256 署名鍵（本番は wrangler secret）
PUBLIC_APP_URL=http://127.0.0.1:3000          # マジックリンクの verify 先ベース URL
IHL_DEV_EXPOSE_MAGIC_TOKEN=                    # =1 のときのみ magic-link 応答に dev_magic_token（本番は未設定）

# ─────────────────────────────────────────────────────────────
# Cloudflare — Workers / Pages / R2。
# 取得: Cloudflare ダッシュボード → 右上 → Account ID、および My Profile → API Tokens で発行。
# ─────────────────────────────────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token        # Workers/Pages/R2 に必要な最小スコープ

# ─────────────────────────────────────────────────────────────
# collector ingest（C3・CL-09/V3-OBS-28）— SwitchBot 単発コレクタと API の署名認証。
# API 側は COLLECTOR_PUBLIC_KEYS（collector_id → Ed25519 SPKI PEM の JSON マップ）で検証。
# コレクタ側（components/collector-switchbot/run.py）は SwitchBot トークン + Ed25519 秘密鍵で署名。
# 実値は D:\env のみ。秘密鍵/トークンはコミットしない（署名は認証＝実鍵投入は人間ゲート）。
# ─────────────────────────────────────────────────────────────
COLLECTOR_PUBLIC_KEYS={"collector-switchbot-01":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"} # API 側: 登録済み公開鍵マップ
SWITCHBOT_TOKEN=your-switchbot-open-token      # SwitchBot アプリ → 開発者オプションで発行
SWITCHBOT_SECRET=your-switchbot-secret         # 同上（v1.1 API HMAC 署名用）
COLLECTOR_ID=collector-switchbot-01            # このコレクタの ID（公開鍵マップのキーと一致）
COLLECTOR_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n # Ed25519 秘密鍵（署名用・実鍵は人間ゲート）
INGEST_URL=http://127.0.0.1:8787/api/v1/collector/ingest # ingest 先
COLLECTOR_USER_ID=u_collector                  # 任意: payload.userId
COLLECTOR_PLACEMENT_ID=pl_default              # 任意: payload.placementId
