{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/ai-profile.schema.json",
  "title": "AI feature profile (差替可能プロファイル)",
  "description": "AI 機能ごとの差替可能プロファイル。provider/model/compute_tier を機能単位で持ち替える。BYOK のみ（サーバ既定 API 鍵フィールドは持たない＝V3-SEC・LLM 既定 OFF＝不変条項①）。compute_tier は UI ラベル 低/中/高/最高（V3-AIP-40）。",
  "x_ihl_req": "V3-AIP-40",
  "x_ihl_source": "docs/planning/c5/design-k8.md §1.3",
  "type": "object",
  "required": ["feature_id", "provider", "model", "compute_tier", "byok"],
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1,
      "description": "対象 AI 機能の識別子（image-analysis / rag / newspaper / translation / market など）。"
    },
    "provider": {
      "type": "string",
      "minLength": 1,
      "description": "モデル提供者。"
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "description": "モデル名。"
    },
    "compute_tier": {
      "type": "string",
      "enum": ["low", "medium", "high", "max"],
      "description": "計算資源目安（UI 低/中/高/最高）。"
    },
    "byok": {
      "type": "boolean",
      "default": true,
      "description": "Bring Your Own Key。既定 true（サーバは鍵を保持しない）。"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "対応機能タグ（任意）。"
    },
    "cost": {
      "type": "object",
      "description": "コスト目安（任意）。"
    },
    "latency": {
      "type": "string",
      "description": "レイテンシ目安（任意）。"
    },
    "rag": {
      "type": "object",
      "description": "RAG 設定（任意）。"
    },
    "prompt": {
      "type": "string",
      "description": "既定プロンプト（ユーザー編集可・任意）。"
    }
  },
  "additionalProperties": false
}
