{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/ind-life-event.schema.json",
  "title": "Individual Life Event data (ihl.ind.life_event.v1)",
  "description": "個体ライフイベント append-only の data 部（誕生／脱皮／死亡／羽化／標本化／移動）。Truth キー truth/ihl.ind.life_event.v1/<individual_id>-<ulid>.json。projectIndividual が at 昇順に timeline へ集約し、projectCross が死亡率等の率系を決定論算出（不変条項①）。",
  "x_ihl_req": "V3-IND-12 / V3-IND-13",
  "x_ihl_source": "docs/planning/c5/design-k1.md §1.2",
  "type": "object",
  "required": ["individual_id", "kind", "at", "actor_id"],
  "properties": {
    "individual_id": {
      "type": "string",
      "minLength": 1,
      "description": "対象個体の individual_id。"
    },
    "kind": {
      "type": "string",
      "enum": ["birth", "molt", "death", "eclosion", "specimen", "move"],
      "description": "ライフイベント種別（誕生／脱皮／死亡／羽化／標本化／移動）。"
    },
    "at": {
      "type": "string",
      "format": "date-time",
      "description": "イベント発生時刻（RFC3339）。timeline の時系列キー。"
    },
    "detail": {
      "type": "object",
      "description": "種別依存の付随情報（任意）。移動先・令齢・標本種別など。",
      "additionalProperties": true
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "description": "記録者の actor_id（V3-AUT-17）。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "記録時刻（RFC3339・任意）。"
    }
  },
  "additionalProperties": false
}
