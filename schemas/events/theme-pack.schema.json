{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/theme-pack.schema.json",
  "title": "Theme pack event (ihl.theme.pack.v1)",
  "description": "テーマパック（色トークンのみ・11 キー）の append-only イベント。Truth キー truth/ihl.theme.pack.v1/<pack_id>.json。fork は parent_pack_id 付き追記で built-in（minimal-light/minimal-dark）まで系譜連結（V3-UIX-14/16）。radius/tap/motion/font/fs-* は全画面共通で pack 上書き対象外。",
  "x_ihl_req": "V3-UIX-14",
  "x_ihl_source": "docs/planning/c5/design-k4.md §1.2 / §1.5",
  "type": "object",
  "required": ["pack_id", "actor_id", "name", "mode", "tokens", "created_at", "schema_version"],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1,
      "description": "パックの一意キー（envelope.id=ULID 由来）。"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "description": "作成者の actor_id（本人スコープ V3-AUT-17）。"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "表示名。"
    },
    "mode": {
      "type": "string",
      "enum": ["light", "dark"],
      "description": "配色モード。"
    },
    "parent_pack_id": {
      "type": "string",
      "minLength": 1,
      "description": "fork 元パック ID（built-in slug または ULID・任意・系譜終端）。"
    },
    "tokens": {
      "type": "object",
      "required": ["bg", "surface", "surface-2", "text", "text-muted", "border", "primary", "primary-text", "focus", "danger", "danger-bg"],
      "properties": {
        "bg": { "type": "string", "minLength": 1 },
        "surface": { "type": "string", "minLength": 1 },
        "surface-2": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "text-muted": { "type": "string", "minLength": 1 },
        "border": { "type": "string", "minLength": 1 },
        "primary": { "type": "string", "minLength": 1 },
        "primary-text": { "type": "string", "minLength": 1 },
        "focus": { "type": "string", "minLength": 1 },
        "danger": { "type": "string", "minLength": 1 },
        "danger-bg": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false,
      "description": "色トークン 11 キー（fork 対象＝色文明のみ）。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "発生時刻（RFC3339）。"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "data スキーマ版。"
    }
  },
  "additionalProperties": false
}
