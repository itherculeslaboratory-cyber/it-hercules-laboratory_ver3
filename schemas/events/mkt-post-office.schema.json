{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/mkt-post-office.schema.json",
  "title": "Post office selection event (ihl.mkt.post_office.v1)",
  "description": "配送見積り用の最寄り郵便局登録イベント（append-only）。Truth キー truth/ihl.mkt.post_office.v1/<post_office_event_id>.json。estimateShipping が局間距離×梱包サイズで送料を投影。住所は保持しない（PII 不使用・不変条項③・V3-MKT-20）。",
  "x_ihl_req": "V3-MKT-20",
  "x_ihl_source": "docs/planning/c5/design-k3.md §2.1",
  "type": "object",
  "required": ["post_office_event_id", "actor_id", "post_office_id", "is_default", "created_at", "schema_version"],
  "properties": {
    "post_office_event_id": {
      "type": "string",
      "minLength": 1,
      "description": "登録イベントの一意キー。"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "description": "登録者の actor_id（V3-AUT-17）。"
    },
    "post_office_id": {
      "type": "string",
      "minLength": 1,
      "description": "郵便局の識別子（住所ではない・距離算出用）。"
    },
    "is_default": {
      "type": "boolean",
      "description": "既定局フラグ（最新の true 行を採用）。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "発生時刻（RFC3339）。"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "data スキーマ版。"
    }
  },
  "additionalProperties": false
}
