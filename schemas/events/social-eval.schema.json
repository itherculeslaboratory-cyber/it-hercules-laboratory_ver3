{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/social-eval.schema.json",
  "title": "Social evaluation event (ihl.social.eval.v1)",
  "description": "コンポーネント/ノードへの社会的評価（vote/like/dislike/favorite/follow/fork/proposal）の append-only イベント。Truth キー truth/ihl.social.eval.v1/<eval_id>.json。projectSocialEval が layer0-3 のみ集計（layer4 除外・本人自己評価除外）。公式ランキングは生成しない（統計のみ・V3-KRM-20）。",
  "x_ihl_req": "V3-KRM-20",
  "x_ihl_source": "docs/planning/c5/design-k3.md §2.1",
  "type": "object",
  "required": ["eval_id", "target_node_id", "target_layer", "rater_id", "kind", "created_at", "schema_version"],
  "properties": {
    "eval_id": {
      "type": "string",
      "minLength": 1,
      "description": "評価イベントの一意キー。"
    },
    "target_node_id": {
      "type": "string",
      "minLength": 1,
      "description": "評価対象ノードの ID。"
    },
    "target_layer": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "description": "対象レイヤー（0-3 のみ集計・layer4 除外）。"
    },
    "rater_id": {
      "type": "string",
      "minLength": 1,
      "description": "評価者の actor_id（V3-AUT-17・自己評価は投影で除外）。"
    },
    "kind": {
      "type": "string",
      "enum": ["vote", "like", "dislike", "favorite", "follow", "fork", "proposal"],
      "description": "評価種別。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "発生時刻（RFC3339）。"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "data スキーマ版。"
    }
  },
  "additionalProperties": false
}
