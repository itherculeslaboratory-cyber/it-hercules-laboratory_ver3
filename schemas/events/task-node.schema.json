{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/task-node.schema.json",
  "title": "Research task node (ihl.research.task_node.v1)",
  "description": "limitations/next_questions/data_gap/失敗クラスタ/愚痴クラスタ由来の研究課題ノード（PPR-17）。Truth キー truth/ihl.research.task_node.v1/<task_id>.json（task_id=決定論 sha1(source_kind|source_ref|normalized_question)→同一入力で同一ノード・冪等 put-if-absent。envelope.id は別途 ulid()）。program は program_id で束ねる別 task_node。taskTree は都度再計算投影。",
  "x_ihl_req": "V3-PPR-17",
  "x_ihl_source": "docs/planning/c5/design-c5.md (K5) §2.2",
  "type": "object",
  "required": ["task_id", "question", "source_kind", "source_ref", "difficulty", "priority", "created_at", "schema_version"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1,
      "description": "決定論キー（storage key と一致・route が算出）。"
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "description": "課題（問い）。"
    },
    "source_kind": {
      "type": "string",
      "enum": ["limitation", "next_question", "data_gap", "failure_cluster", "complaint_cluster"],
      "description": "生成源。"
    },
    "source_ref": {
      "type": "string",
      "minLength": 1,
      "description": "生成源イベント／対象の参照。"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "researcher"],
      "description": "難易度。"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "優先度（0–100・ヒューリスティック算出）。"
    },
    "program_id": {
      "type": "string",
      "description": "束ねる program の task_id（任意）。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "生成時刻（RFC3339）。"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "data スキーマ版（例: '1'）。"
    }
  },
  "additionalProperties": false
}
