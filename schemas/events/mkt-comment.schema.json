{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/mkt-comment.schema.json",
  "title": "Market listing public comment (ihl.mkt.comment.v1)",
  "description": "出品(listing)の公開コメント append-only イベント(V3-MKT-03)。マッチング前の公開画面は「商品詳細+公開Q&A+ほめボードのみ」— この2種を1つの型で持つ。Truth キー truth/ihl.mkt.comment.v1/<listing_id>/<comment_id>.json。kind=question/praise は誰でも投稿可、kind=answer は出品者のみ(route ガード)で parent_comment_id(質問)必須。全件マッチング前後を問わず公開(非削除)。",
  "x_ihl_req": "V3-MKT-03",
  "x_ihl_source": "docs/planning/c5/design-k3.md §2.1 / 06-マーケット.md §11.0",
  "type": "object",
  "required": ["comment_id", "listing_id", "actor_id", "kind", "body", "created_at", "schema_version"],
  "properties": {
    "comment_id": {
      "type": "string",
      "minLength": 1,
      "description": "コメントの一意キー(ULID)。"
    },
    "listing_id": {
      "type": "string",
      "minLength": 1,
      "description": "対象出品の listing_id。"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "description": "投稿者の actor_id(セッション principal 強制・V3-AUT-17)。"
    },
    "kind": {
      "type": "string",
      "enum": ["question", "answer", "praise"],
      "description": "公開Q&Aの質問/回答、またはほめボードのほめコメント。"
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "本文。"
    },
    "parent_comment_id": {
      "type": "string",
      "minLength": 1,
      "description": "kind=answer のとき対象質問の comment_id(必須・route + schema 二重強制)。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "投稿時刻(RFC3339)。"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "data スキーマ版。"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "kind": { "const": "answer" } },
    "required": ["kind"]
  },
  "then": {
    "required": ["parent_comment_id"]
  }
}
