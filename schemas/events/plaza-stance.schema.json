{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.it-hercules.uk/events/plaza-stance.schema.json",
  "title": "Plaza stance data (ihl.plaza.stance.v1)",
  "description": "Polis 型の賛否表明イベント ihl.plaza.stance.v1 の data 部（BBS-36）。Truth キー truth/ihl.plaza.stance.v1/<statement_id>/<stance_id>.json に append-only。同 actor の再投票は projectConsensus が最新 ULID を latest として採用（上書きせず追記）。consensus/divisive は決定論算術で都度投影（LLM 不要）。",
  "x_ihl_req": "V3-BBS-36",
  "x_ihl_source": "docs/planning/c5/design-c5.md §K6 §2.2",
  "type": "object",
  "required": ["stance_id", "actor_id", "statement_id", "value", "created_at", "schema_version"],
  "properties": {
    "stance_id": {
      "type": "string",
      "minLength": 1,
      "description": "表明の一意キー（ULID）。"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "description": "表明者の actor_id（セッション principal 強制・V3-AUT-17）。"
    },
    "statement_id": {
      "type": "string",
      "minLength": 1,
      "description": "対象ステートメント（=post_id 等）。"
    },
    "value": {
      "type": "string",
      "enum": ["agree", "disagree", "pass"],
      "description": "賛否（Agree/Disagree/Pass・BBS-36）。"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "表明時刻（RFC3339）。"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "data スキーマ版。"
    }
  },
  "additionalProperties": false
}
