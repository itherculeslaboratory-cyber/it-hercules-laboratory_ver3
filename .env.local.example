# .env.local.example — ユーザー/デバイス層の設定「型」テンプレート（V3-CST-05）。
# 対象: SwitchBot コレクタを自分の場所で動かす各ユーザー。管理者/インフラ鍵は含まない。
# 使い方: このファイルを .env.local（.gitignore 済）へコピーし、自分の SwitchBot トークンと
# コレクタ鍵で埋める。秘密鍵/トークンは絶対にコミットしない（署名＝認証・実鍵は人間ゲート）。
# 管理者/インフラの設定（GMO/Resend/CF/CORS/AI/公開鍵マップ）は .env.platform.example を参照。

# ─────────────────────────────────────────────────────────────
# SwitchBot v1.1 API — コレクタが機器を読むためのトークン。
# 取得: SwitchBot アプリ → プロフィール → 開発者オプション で発行（token + secret）。
# ─────────────────────────────────────────────────────────────
SWITCHBOT_TOKEN=your-switchbot-open-token      # SwitchBot Open Token
SWITCHBOT_SECRET=your-switchbot-secret         # v1.1 API HMAC 署名用 secret

# ─────────────────────────────────────────────────────────────
# コレクタ本体（components/collector-switchbot/run.py）の署名・宛先設定。
# COLLECTOR_ID は API 側 COLLECTOR_PUBLIC_KEYS のキーと一致させる。
# COLLECTOR_PRIVATE_KEY_PEM は Ed25519 秘密鍵（ingest 署名用・実鍵は人間ゲート）。
# ─────────────────────────────────────────────────────────────
COLLECTOR_ID=collector-switchbot-01            # このコレクタの ID（公開鍵マップのキーと一致）
COLLECTOR_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n # Ed25519 秘密鍵（署名用・実鍵は人間ゲート）
INGEST_URL=http://127.0.0.1:8787/api/v1/collector/ingest # ingest 先エンドポイント
COLLECTOR_USER_ID=u_collector                  # 任意: payload.userId
COLLECTOR_PLACEMENT_ID=pl_default              # 任意: payload.placementId（設置場所 ID）
